+
+export function AuthEventListener() {
+  const router = useRouter()
+  const queryClient = useQueryClient()
+
+  React.useEffect(() => {
+    return onAuthUnauthorized(() => {
+      clearAuthToken()
+      queryClient.clear()
+
+      if (window.location.pathname !== "/login") {
+        router.replace("/login")
+      }
+    })
+  }, [queryClient, router])
+
+  return null
+}
